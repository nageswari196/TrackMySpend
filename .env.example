# Copy this file to .env and fill in as needed. All settings are optional --
# the app runs fine with none of these set, using sensible defaults.

# Path to the tesseract executable. Leave unset to auto-detect on PATH.
# Windows example: TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
# Mac (homebrew) example: TESSERACT_CMD=/opt/homebrew/bin/tesseract
# Linux example: TESSERACT_CMD=/usr/bin/tesseract
TESSERACT_CMD=

# SQLite database file path.
DB_FILE=expenses.db

# Set this to enable natural-language answers in the AI Assistant page via
# the real Claude API. Without it, the assistant falls back to rule-based
# keyword matching (still fully functional).
ANTHROPIC_API_KEY=
